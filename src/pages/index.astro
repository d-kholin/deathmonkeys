---
import BaseLayout from '../layouts/BaseLayout.astro';
import EventCard from '../components/EventCard.astro';
import RosterCard from '../components/RosterCard.astro';
import GalleryCard from '../components/GalleryCard.astro';
import { getCollection } from 'astro:content';

const allEvents = await getCollection('events');
const events = allEvents.sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());

const allMembers = await getCollection('roster');
const members = allMembers.sort((a, b) => {
  if (a.data.active === b.data.active) return 0;
  return a.data.active ? -1 : 1;
});

const allGallery = await getCollection('gallery');
const galleryEntries = allGallery.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Death Monkeys" bodyClass="bg-transparent">
  <!-- Fixed background image — stays in place while content scrolls -->
  <div
    id="fixed-bg"
    class="hero-fixed-bg"
    style="position: fixed; inset: 0; z-index: -2; background-image: url('/images/hero-bg.png'); background-repeat: no-repeat;"
    aria-hidden="true"
  ></div>
  <!-- Scroll-driven overlay — darkens as user scrolls into content -->
  <div
    id="bg-overlay"
    style="position: fixed; inset: 0; z-index: -1; background: black; opacity: 0.1;"
    aria-hidden="true"
  ></div>

  <!-- Hero: full viewport, logo in background does the talking -->
  <!-- min-height fallback for older browsers; dvh accounts for iOS Safari's address bar -->
  <section aria-label="Hero" style="min-height: 90vh; min-height: 90dvh; position: relative;">
    <div
      aria-hidden="true"
      style="position: absolute; bottom: 2.5rem; bottom: calc(2.5rem + env(safe-area-inset-bottom)); left: 50%; transform: translateX(-50%);"
    >
      <svg
        class="scroll-cue"
        width="28"
        height="28"
        viewBox="0 0 24 24"
        fill="none"
        stroke="#8aad3a"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <polyline points="6 9 12 15 18 9" />
      </svg>
    </div>
  </section>

  <!-- About -->
  <section id="about">
    <div class="max-w-3xl mx-auto px-[var(--spacing-xl)] py-[var(--spacing-3xl)]">
      <p class="section-eyebrow mb-[var(--spacing-2xl)]">About</p>
      <p class="text-text-secondary text-base leading-relaxed mb-[var(--spacing-2xl)]">
        We are the Death Monkeys — a tactical airsoft unit operating out of Badlands field in Alberta.
        Part milsim crew, part chaos agents.
      </p>

      <div class="mb-[var(--spacing-2xl)]">
        <h2 class="section-subhead mb-[var(--spacing-md)]">Who We Are</h2>
        <p class="text-text-secondary text-base leading-relaxed mb-[var(--spacing-md)]">
          The Death Monkeys are a small-unit airsoft team that takes the game seriously — but never
          themselves. We run coordinated multi-role operations, communicate on comms, and hold
          objectives with tactical discipline. Then we argue about who got hit first and laugh about
          it over hot dogs.
        </p>
        <p class="text-text-secondary text-base leading-relaxed">
          Founded by Nakunga (Naku) with a mandate to have the most fun per trigger pull of any
          team on the field, the Death Monkeys have grown from a two-person squad into a full
          operational element with dedicated assaulters, support gunners, and recon specialists.
        </p>
      </div>

      <div class="mb-[var(--spacing-2xl)]">
        <h2 class="section-subhead mb-[var(--spacing-md)]">Where We Play</h2>
        <p class="text-text-secondary text-base leading-relaxed">
          Our home field is <strong class="text-text-primary">Badlands field, Alberta</strong>.
          The terrain is varied, the weather is unpredictable, and the cover is exactly right for
          the kind of chaos we prefer. We run ops on scheduled game days and occasionally book
          private team training sessions when Command decides we need to sharpen our edge.
        </p>
      </div>

      <div class="mb-[var(--spacing-2xl)]">
        <h2 class="section-subhead mb-[var(--spacing-md)]">Ethos</h2>
        <ul class="space-y-[var(--spacing-sm)] text-text-secondary text-base leading-relaxed list-none">
          <li class="border-l-2 border-accent pl-[var(--spacing-md)]">
            <strong class="text-text-primary">Call your hits.</strong> Every time. No exceptions. The game only works if we're all honest.
          </li>
          <li class="border-l-2 border-accent pl-[var(--spacing-md)]">
            <strong class="text-text-primary">Communicate.</strong> Silence is how operations fall apart. Get on comms and use them.
          </li>
          <li class="border-l-2 border-accent pl-[var(--spacing-md)]">
            <strong class="text-text-primary">Debrief everything.</strong> After every engagement there is an AAR. What worked, what didn't, and who got lit up from behind again.
          </li>
          <li class="border-l-2 border-accent pl-[var(--spacing-md)]">
            <strong class="text-text-primary">Leave the ego at the gate.</strong> We're here to improve and to enjoy the game. New players get patience, not grief.
          </li>
        </ul>
      </div>

      <div id="join">
        <h2 class="section-subhead mb-[var(--spacing-md)]">Want In?</h2>
        <p class="text-text-secondary text-base leading-relaxed mb-[var(--spacing-lg)]">
          We welcome players of all experience levels. If you can follow commands, call your hits,
          and laugh when things go sideways, you'll fit right in. Show up to a field day, introduce
          yourself, and let your trigger finger do the talking.
        </p>
        <a
          href="#roster"
          class="inline-block bg-accent text-text-primary font-heading font-bold uppercase tracking-[0.05em] px-[var(--spacing-lg)] py-[var(--spacing-sm)] hover:opacity-90 transition-opacity"
        >
          View the Roster
        </a>
      </div>
    </div>
  </section>

  <!-- Events -->
  <section id="events" class="border-t border-border">
    <div class="max-w-3xl mx-auto px-[var(--spacing-xl)] py-[var(--spacing-3xl)]">
      <p class="section-eyebrow mb-[var(--spacing-2xl)]">Events</p>
      {events.length === 0 ? (
        <div class="text-center py-[var(--spacing-3xl)]">
          <p class="font-heading text-[20px] font-bold uppercase tracking-[0.05em] text-text-primary mb-[var(--spacing-md)]">No Operations Scheduled</p>
          <p class="text-text-muted text-base">Check back soon — Command is planning the next op.</p>
        </div>
      ) : (
        <div class="flex flex-col gap-[var(--spacing-md)]">
          {events.map((event) => <EventCard {...event.data} />)}
        </div>
      )}
    </div>
  </section>

  <!-- Roster -->
  <section id="roster" class="border-t border-border">
    <div class="max-w-3xl mx-auto px-[var(--spacing-xl)] py-[var(--spacing-3xl)]">
      <p class="section-eyebrow mb-[var(--spacing-2xl)]">Roster</p>
      {members.length === 0 ? (
        <div class="text-center py-[var(--spacing-3xl)]">
          <p class="font-heading text-[20px] font-bold uppercase tracking-[0.05em] text-text-primary mb-[var(--spacing-md)]">No Operators Found</p>
          <p class="text-text-muted text-base">The team roster is currently classified.</p>
        </div>
      ) : (
        <div class="flex flex-col gap-[var(--spacing-md)]">
          {members.map((member) => <RosterCard {...member.data} />)}
        </div>
      )}
    </div>
  </section>

  <!-- Gallery -->
  <section id="gallery" class="border-t border-border">
    <div class="max-w-4xl mx-auto px-[var(--spacing-xl)] py-[var(--spacing-3xl)]">
      <p class="section-eyebrow mb-[var(--spacing-2xl)]">Gallery</p>
      {galleryEntries.length === 0 ? (
        <div class="text-center py-[var(--spacing-3xl)]">
          <p class="font-heading text-[20px] font-bold uppercase tracking-[0.05em] text-text-primary mb-[var(--spacing-md)]">No After-Action Reports</p>
          <p class="text-text-muted text-base">No ops have been documented yet. Check back after the next engagement.</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-[var(--spacing-lg)]">
          {galleryEntries.map((entry) => <GalleryCard id={entry.id} {...entry.data} />)}
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<script>
  const overlay = document.getElementById('bg-overlay') as HTMLElement;
  const maxScroll = window.innerHeight * 0.8;

  window.addEventListener('scroll', () => {
    const opacity = 0.1 + (Math.min(window.scrollY, maxScroll) / maxScroll) * 0.72;
    overlay.style.opacity = opacity.toFixed(3);
  }, { passive: true });
</script>
