---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('gallery');
  return entries.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const formattedDate = entry.data.date.toLocaleDateString('en-CA', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${entry.data.title} — Death Monkeys`}>
  <div class="max-w-4xl mx-auto px-[var(--spacing-xl)] py-[var(--spacing-3xl)]">
    <!-- Back link -->
    <a
      href="/gallery"
      class="inline-block text-[14px] text-text-muted hover:text-text-primary mb-[var(--spacing-2xl)] transition-colors"
    >
      &larr; Back to Gallery
    </a>

    <!-- Header -->
    <header class="mb-[var(--spacing-2xl)]">
      <p class="text-[14px] text-text-muted mb-[var(--spacing-xs)]">{formattedDate}</p>
      {entry.data.eventRef && (
        <p class="text-[14px] text-text-muted mb-[var(--spacing-sm)]">
          Event: <span class="text-text-secondary">{entry.data.eventRef}</span>
        </p>
      )}
      <h1 class="font-heading text-[20px] font-bold uppercase tracking-[0.05em] text-text-primary mb-[var(--spacing-md)]">
        {entry.data.title}
      </h1>
      <p class="text-base text-text-secondary leading-relaxed">
        {entry.data.summary}
      </p>
    </header>

    <!-- Photos -->
    {entry.data.photos && entry.data.photos.length > 0 && (
      <section class="mb-[var(--spacing-2xl)]">
        <h2 class="font-heading text-[20px] font-bold uppercase tracking-[0.05em] text-text-primary mb-[var(--spacing-lg)]">
          PHOTOS
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-[var(--spacing-md)]">
          {entry.data.photos.map((photoUrl: string) => (
            <img
              src={photoUrl}
              alt={entry.data.title}
              width="800"
              height="600"
              class="w-full object-cover border-2 border-[#1f2937]"
              loading="lazy"
            />
          ))}
        </div>
      </section>
    )}

    <!-- AAR Body -->
    <article class="prose prose-invert max-w-none text-text-secondary leading-relaxed">
      <Content />
    </article>
  </div>
</BaseLayout>
