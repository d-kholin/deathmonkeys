---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GalleryCard from '../../components/GalleryCard.astro';
import { getCollection } from 'astro:content';

const allEntries = await getCollection('gallery');
// Sort descending by date (newest first)
const entries = allEntries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Gallery — Death Monkeys">
  <div class="max-w-4xl mx-auto px-[var(--spacing-xl)] py-[var(--spacing-3xl)]">
    <h1 class="font-heading text-[20px] font-bold uppercase tracking-[0.05em] text-text-primary mb-[var(--spacing-2xl)]">
      GALLERY
    </h1>

    {entries.length === 0 ? (
      <div class="text-center py-[var(--spacing-3xl)]">
        <p class="font-heading text-[20px] font-bold uppercase tracking-[0.05em] text-text-primary mb-[var(--spacing-md)]">
          No After-Action Reports
        </p>
        <p class="text-text-muted text-base">
          No ops have been documented yet. Check back after the next engagement.
        </p>
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-[var(--spacing-lg)]">
        {entries.map((entry) => (
          <GalleryCard id={entry.id} {...entry.data} />
        ))}
      </div>
    )}
  </div>
</BaseLayout>
