---
import BaseLayout from '../layouts/BaseLayout.astro';
import EventCard from '../components/EventCard.astro';
import { getCollection } from 'astro:content';

const allEvents = await getCollection('events');
const events = allEvents.sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());
---

<BaseLayout title="Events — Death Monkeys">
  <div class="max-w-3xl mx-auto px-[var(--spacing-xl)] py-[var(--spacing-3xl)]">
    <h1 class="font-heading text-[20px] font-bold uppercase tracking-[0.05em] text-text-primary mb-[var(--spacing-2xl)]">
      EVENTS
    </h1>

    {events.length === 0 ? (
      <div class="text-center py-[var(--spacing-3xl)]">
        <p class="font-heading text-[20px] font-bold uppercase tracking-[0.05em] text-text-primary mb-[var(--spacing-md)]">
          No Operations Scheduled
        </p>
        <p class="text-text-muted text-base">
          Check back soon — Command is planning the next op.
        </p>
      </div>
    ) : (
      <div class="flex flex-col gap-[var(--spacing-md)]">
        {events.map((event) => (
          <EventCard {...event.data} />
        ))}
      </div>
    )}
  </div>
</BaseLayout>
