---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  bodyClass?: string;
}

const { title, bodyClass } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body class={`bg-surface text-text-primary font-body${bodyClass ? ` ${bodyClass}` : ''}`}>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
