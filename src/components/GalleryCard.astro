---
interface Props {
  id: string;
  title: string;
  date: Date;
  summary: string;
  photos?: string[];
}

const { id, title, date, summary, photos } = Astro.props;

const formattedDate = date.toLocaleDateString('en-CA', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Use first provided photo or a stable placeholder
const imageUrl = photos && photos.length > 0
  ? photos[0]
  : `https://picsum.photos/seed/${id}/800/400`;
---

<a
  href={`/gallery/${id}`}
  class="group block bg-surface-raised border-2 border-[#1f2937] hover:border-accent transition-colors overflow-hidden"
>
  <img
    src={imageUrl}
    alt={title}
    width="800"
    height="400"
    class="w-full h-48 object-cover"
    loading="lazy"
  />
  <div class="p-[var(--spacing-lg)]">
    <p class="text-[14px] text-text-muted mb-[var(--spacing-xs)]">{formattedDate}</p>
    <h3 class="font-heading text-[20px] font-bold leading-[1.2] text-text-primary mb-[var(--spacing-sm)]">
      {title}
    </h3>
    <p class="text-base text-text-secondary leading-relaxed line-clamp-3">
      {summary}
    </p>
  </div>
</a>
