---
interface Props {
  title: string;
  date: Date;
  location: string;
  description: string;
  cancelled: boolean;
  directionsUrl?: string;
}

const { title, date, location, description, cancelled, directionsUrl } = Astro.props;

const formattedDate = date.toLocaleDateString('en-CA', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Derive status at build time from date and cancelled flag.
// Normalize both sides to midnight so time-of-day doesn't affect the comparison.
type EventStatus = 'upcoming' | 'in-progress' | 'past' | 'cancelled';

let computedStatus: EventStatus;
if (cancelled) {
  computedStatus = 'cancelled';
} else {
  const today = new Date();
  today.setHours(0, 0, 0, 0);
  const eventDay = new Date(date);
  eventDay.setHours(0, 0, 0, 0);

  if (eventDay.getTime() > today.getTime()) {
    computedStatus = 'upcoming';
  } else if (eventDay.getTime() === today.getTime()) {
    computedStatus = 'in-progress';
  } else {
    computedStatus = 'past';
  }
}

const badgeConfig: Record<EventStatus, { label: string; classes: string }> = {
  upcoming:    { label: 'UPCOMING',           classes: 'bg-accent text-text-primary' },
  'in-progress': { label: 'OP IN PROGRESS',   classes: 'bg-accent text-text-primary animate-pulse' },
  past:        { label: 'PREVIOUS OPERATION', classes: 'bg-badge-completed text-text-secondary' },
  cancelled:   { label: 'CANCELLED',          classes: 'bg-destructive text-text-primary' },
};

const badge = badgeConfig[computedStatus];
---

<article class="group relative bg-surface-raised p-[var(--spacing-lg)] border-l-2 border-l-transparent hover:border-l-accent transition-colors">
  <div class="flex items-start justify-between gap-[var(--spacing-md)] mb-[var(--spacing-sm)]">
    <h3 class="font-heading text-[20px] font-bold leading-[1.2] text-text-primary">
      {title}
    </h3>
    <span class={`shrink-0 inline-block text-[14px] leading-[1.4] uppercase tracking-[0.05em] px-[var(--spacing-sm)] py-[var(--spacing-xs)] ${badge.classes}`}>
      {badge.label}
    </span>
  </div>
  <div class="flex flex-wrap gap-x-[var(--spacing-md)] gap-y-[var(--spacing-xs)] text-[14px] text-text-muted mb-[var(--spacing-md)]">
    <span>{formattedDate}</span>
    {directionsUrl ? (
      <a href={directionsUrl} target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">{location} ↗</a>
    ) : (
      <span>{location}</span>
    )}
  </div>
  <p class="text-base text-text-secondary leading-relaxed">
    {description}
  </p>
</article>
